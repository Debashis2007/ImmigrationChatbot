# Copy this file to .env and update with your values

# Core stack environment
# LLM provider: openai | ollama
LLM_ENABLED=true
LLM_PROVIDER=ollama
LLM_TIMEOUT_SECONDS=30

# OpenAI-compatible settings
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b

# Memory store (SQLite local by default, Postgres in production)
# MEMORY_BACKEND: sql | firebase
MEMORY_BACKEND=sql
DATABASE_URL=sqlite:///./chatbot.db

# Firebase settings (used when MEMORY_BACKEND=firebase)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_COLLECTION=chat_messages

# Optional API key auth for backend
API_AUTH_ENABLED=false
API_AUTH_KEY=replace_with_secure_api_key

# Frontend API target
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=
